{
  "name": "otc-lab-mobile-v2",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_ROUTER_APP_ROOT=src/app expo start",
    "dev:clear": "EXPO_ROUTER_APP_ROOT=src/app expo start -c",
    "dev:tunnel": "EXPO_ROUTER_APP_ROOT=src/app expo start --tunnel",
    "ios": "EXPO_ROUTER_APP_ROOT=src/app expo run:ios",
    "android": "EXPO_ROUTER_APP_ROOT=src/app expo run:android",
    "lint": "eslint src --ext .tsx,.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^3.9.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.62.11",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "^8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.10",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
